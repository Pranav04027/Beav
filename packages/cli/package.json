{
  "name": "@beav/cli",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "beav": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@beav/core": "workspace:*",
    "@beav/orchestrator": "workspace:*"
  }
}
